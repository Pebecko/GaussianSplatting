[submodule "external/glWrappers"]
	path = external/glWrappers
	url = https://github.com/Pebecko/GLWrappers.git
[submodule "external/glm"]
	path = external/glm
	url = https://github.com/g-truc/glm.git
[submodule "external/stb/include/stb"]
	path = external/stb/include/stb
	url = https://github.com/nothings/stb.git
[submodule "external/glfw"]
	path = external/glfw
	url = https://github.com/glfw/glfw.git
[submodule "external/assimp"]
	path = external/assimp
	url = https://github.com/assimp/assimp.git
